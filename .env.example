# Copy to .env and fill in ( .env is gitignored — never commit secrets )

PORT=4000
NODE_ENV=development

# --- Supabase (SuperMKT project xmilhrvlmwkcphtheanx) ---
# Get URI: Supabase → Connect → Session pooler
DATABASE_URL=postgresql://postgres.xmilhrvlmwkcphtheanx:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true
PGSSL_REJECT_UNAUTHORIZED=0

# Supabase only — do not set DB_PATH, DB_BACKEND, or LOCAL_SQLITE_FALLBACK.
# Run 001_init_postgres.sql then 002_seed_demo_supabase.sql in Supabase SQL Editor once.
# PG_RUN_MIGRATION=1  # optional: run 001_init_postgres.sql from Node (usually use SQL Editor instead)

JWT_SECRET=your-secret-key-change-in-production

