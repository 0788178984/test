# Server Configuration
PORT=4000
NODE_ENV=development

# Database (SQLite). Relative paths are from the **repository root** (folder that contains `server/`), not from `server/`.
# Default if unset: <repo>/data/supermarket.db
DB_PATH=./data/supermarket.db

# Set to 1 only to wipe ALL tenants and reseed demo data (requires confirmation via seed script).
# FORCE_SEED=1

# Authentication (required in production; must not stay on the placeholder)
JWT_SECRET=your-secret-key-change-in-production

# Optional: strong password for seeded developer (used by npm run setup / seed only)
# DEVELOPER_PASSWORD=

# Optional: on startup, if there are zero users, run demo seed (Render free has no Shell — set once, deploy, then remove)
# SEED_IF_EMPTY=1

# Legacy global MoMo env (optional fallback for old scripts). Store POS uses per-business keys from Developer Console.
# MTN_PRIMARY_KEY=
# MTN_API_SECRET=

# Africa's Talking SMS/WhatsApp
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key
AT_SENDER_ID=SUPERMARKET

# WhatsApp
WHATSAPP_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_ID=123456789012345

# MTN Mobile Money
MTN_PRIMARY_KEY=your-mtn-primary-key
MTN_SECONDARY_KEY=your-mtn-secondary-key
MTN_USER_ID=your-mtn-user-id
MTN_API_SECRET=your-mtn-api-secret
MTN_ENVIRONMENT=sandbox

# Airtel Money
AIRTEL_CLIENT_ID=your-airtel-client-id
AIRTEL_CLIENT_SECRET=your-airtel-client-secret

# Sync Configuration
CLOUD_API_URL=https://api.ugandasupermarket.com
MACHINE_ID=machine-001
MACHINE_SECRET=your-machine-secret

# Client (optional; defaults to http://localhost:4000)
# VITE_API_URL=http://localhost:4000

# Reverse proxy (set TRUST_PROXY=1 behind nginx/Cloudflare so rate limits use real client IP)
# TRUST_PROXY=1

# Logging: error | warn | info | debug (production defaults to warn if unset)
# LOG_LEVEL=info

# Rate limits (per IP, per window)
# RATE_LIMIT_AUTH_MAX=80
# RATE_LIMIT_API_MAX=2000
