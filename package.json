{
  "name": "uganda-supermarket",
  "version": "1.0.0",
  "description": "Uganda Supermarket Management System - Offline-first with cloud sync",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && npm run dev",
    "client:dev": "cd client && npm run dev",
    "desktop:dev": "cd desktop && npm run dev",
    "build": "npm run client:build && npm run desktop:build",
    "client:build": "cd client && npm run build",
    "desktop:build": "cd desktop && npm run build",
    "render-build": "NPM_CONFIG_PRODUCTION=false npm install && npm run client:build",
    "start": "cd server && npm start",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install && cd ../desktop && npm install && cd ../cloud && npm install",
    "setup": "npm run install:all",
    "db:counts": "node server/scripts/show-db-counts.js",
    "db:test-connect": "node server/scripts/test-pg-connect.js",
    "validate:auth": "node scripts/validate-auth.cjs",
    "validate:auth:http": "node scripts/validate-auth.cjs --http"
  },
  "keywords": [
    "supermarket",
    "pos",
    "uganda",
    "offline-first",
    "electron",
    "react",
    "nodejs"
  ],
  "author": "Uganda Supermarket Solutions",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "server",
    "client",
    "desktop",
    "cloud"
  ]
}
